graph TD
  Req["Lean request"] --> Route{"request_type"}
  Route -->|initialize_case| Init["initializeCase"]
  Route -->|next_opportunity| Next["nextOpportunity"]
  Route -->|step| StepIn["step(state, action)"]

  Init --> InitCheck{"proposition,\nevidence standard,\nand council valid?"}
  InitCheck -->|no| InitErr["error"]
  InitCheck -->|yes| InitOut["set status=active\nphase=openings\nseated council\nround=1"]

  Next --> Status{"case status"}
  Status -->|closed| Closed["terminal with resolution"]
  Status -->|active| Phase{"phase"}

  Phase -->|openings| Openings["plaintiff then defendant opening"]
  Phase -->|arguments| Arguments["plaintiff then defendant merits argument"]
  Phase -->|rebuttals| Rebuttal["plaintiff rebuttal opportunity\nmay pass"]
  Phase -->|surrebuttals| Surrebuttal["defendant surrebuttal opportunity\nmay pass"]
  Phase -->|closings| Closings["plaintiff then defendant closing"]
  Phase -->|deliberation| Delib["next unvoted council member\nin current round"]
  Phase -->|closed| Closed
  Phase -->|other| NextErr["terminal invalid_phase:*"]

  Openings --> NextOut["current opportunity"]
  Arguments --> NextOut
  Rebuttal --> NextOut
  Surrebuttal --> NextOut
  Closings --> NextOut
  Delib --> DelibState{"unvoted member remains?"}
  DelibState -->|yes| NextOut
  DelibState -->|no| Wait["terminal awaiting_deliberation_resolution"]

  StepIn --> SchemaCheck{"action_type"}
  SchemaCheck --> OpeningAct["record_opening_statement"]
  SchemaCheck --> ArgumentAct["submit_argument"]
  SchemaCheck --> RebuttalAct["submit_rebuttal"]
  SchemaCheck --> SurrebuttalAct["submit_surrebuttal"]
  SchemaCheck --> ClosingAct["deliver_closing_statement"]
  SchemaCheck --> PassAct["pass_phase_opportunity"]
  SchemaCheck --> VoteAct["submit_council_vote"]
  SchemaCheck --> StepErr["error"]

  OpeningAct --> OpeningCheck{"phase=openings\ncorrect side\ntext within limit"}
  OpeningCheck -->|no| OpeningErr["error"]
  OpeningCheck -->|yes| OpeningWrite["append filing\nadvance to arguments after two openings"]

  ArgumentAct --> ArgumentCheck{"phase=arguments\ncorrect side\ntext within limit"}
  ArgumentCheck -->|no| ArgumentErr["error"]
  ArgumentCheck -->|yes| ArgumentWrite["append filing\nappend offered files\nappend technical reports\nadvance to rebuttals after two arguments"]

  RebuttalAct --> RebuttalCheck{"phase=rebuttals\nactor=plaintiff\ntext within limit"}
  RebuttalCheck -->|no| RebuttalErr["error"]
  RebuttalCheck -->|yes| RebuttalWrite["append filing\nappend offered files\nappend technical reports\nadvance to surrebuttals"]

  SurrebuttalAct --> SurrebuttalCheck{"phase=surrebuttals\nactor=defendant\ntext within limit\nno supplemental materials"}
  SurrebuttalCheck -->|no| SurrebuttalErr["error"]
  SurrebuttalCheck -->|yes| SurrebuttalWrite["append filing\nadvance to closings"]

  ClosingAct --> ClosingCheck{"phase=closings\ncorrect side\ntext within limit"}
  ClosingCheck -->|no| ClosingErr["error"]
  ClosingCheck -->|yes| ClosingWrite["append filing\nadvance to deliberation after two closings"]

  PassAct --> PassCheck{"phase=rebuttals or surrebuttals\ncorrect side\nno prior filing"}
  PassCheck -->|no| PassErr["error"]
  PassCheck -->|yes| PassWrite["advance to next merits phase"]

  VoteAct --> VoteCheck{"phase=deliberation\nactor=council\nmember known\nvalid vote\nnot already voted"}
  VoteCheck -->|no| VoteErr["error"]
  VoteCheck -->|yes| VoteWrite["append vote for current round"]
  VoteWrite --> VoteResult{"majority reached?"}
  VoteResult -->|substantially_true| CloseTrue["set status=closed\nphase=closed\nresolution=substantially_true"]
  VoteResult -->|not_substantially_true| CloseFalse["set status=closed\nphase=closed\nresolution=not_substantially_true"]
  VoteResult -->|no majority| RoundCheck{"all members voted?"}
  RoundCheck -->|no| VoteStay["state updated\nsame deliberation round"]
  RoundCheck -->|yes and max rounds reached| CloseNone["set status=closed\nphase=closed\nresolution=no_majority"]
  RoundCheck -->|yes and more rounds allowed| NextRound["increment deliberation_round"]

  OpeningWrite --> StepOut["updated ArbitrationState"]
  ArgumentWrite --> StepOut
  RebuttalWrite --> StepOut
  SurrebuttalWrite --> StepOut
  ClosingWrite --> StepOut
  PassWrite --> StepOut
  VoteStay --> StepOut
  NextRound --> StepOut
  CloseTrue --> StepOut
  CloseFalse --> StepOut
  CloseNone --> StepOut
