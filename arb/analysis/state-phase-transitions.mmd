graph LR
  subgraph CaseStatus["Case status"]
    draft["draft"]
    active["active"]
    closed["closed"]

    draft --> active
    active --> closed
  end

  subgraph CasePhase["Case phase"]
    p_draft["draft"]
    p_open["openings"]
    p_arg["arguments"]
    p_reb["rebuttals"]
    p_sur["surrebuttals"]
    p_close["closings"]
    p_delib["deliberation"]
    p_closed["closed"]

    p_draft --> p_open --> p_arg --> p_reb --> p_sur --> p_close --> p_delib --> p_closed
  end

  note_init["Initialization rule:<br/>initialize_case sets status=active and phase=openings."]
  note_open["Openings rule:<br/>after plaintiff and defendant openings, phase advances to arguments."]
  note_arg["Arguments rule:<br/>after plaintiff and defendant arguments, phase advances to rebuttals."]
  note_reb["Rebuttal rule:<br/>plaintiff may submit a rebuttal with targeted exhibits and technical reports, or pass.<br/>Either path advances to surrebuttals."]
  note_sur["Surrebuttal rule:<br/>defendant may submit a surrebuttal or pass.<br/>Surrebuttal is text-only.<br/>Either path advances to closings."]
  note_close["Closings rule:<br/>after plaintiff and defendant closings, phase advances to deliberation."]
  note_delib["Deliberation rule:<br/>votes remain in deliberation until a majority closes the case or the final round closes it as no_majority."]
  note_status["Status rule:<br/>the engine never returns to draft after initialization.<br/>Every final resolution closes the case."]

  p_open -.-> note_open
  p_arg -.-> note_arg
  p_reb -.-> note_reb
  p_sur -.-> note_sur
  p_close -.-> note_close
  p_delib -.-> note_delib
  active -.-> note_status
  draft -.-> note_init
